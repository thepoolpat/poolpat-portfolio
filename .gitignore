node_modules/
dist/
.astro/
.DS_Store
.env
.env.*
!.env.example
# data/.fetch_failures.json is intentionally committed: the consecutive-failure
# counter must persist across CI runs or the alert threshold can never trigger.
*.p8
*.pem
*.key

# Python cache and test artifacts
pipeline/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
.pytest_cache/
coverage/
.coverage
htmlcov/

# OAuth cache directories
~/.cache/spotify_oauth/
~/.cache/spotify_oauth_auth/

# Camoufox artifacts
camoufox/
~/.camoufox/
*.camoufox

# Local analytics DBs (regenerated by dev/run_batch*.py)
dev/spotify_logs/*.db

# Local Spotify export CSV (regenerated by dev tooling)
dev/spotify_logs/*.csv

# Local agent session state
.claude/
.hermes/

# Local scratch scripts (one-shot debugging, not part of the pipeline)
scratch/
