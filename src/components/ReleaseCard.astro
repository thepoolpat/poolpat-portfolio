---
import type { CollectionEntry } from "astro:content";

interface Props {
  release: CollectionEntry<"releases">["data"];
  showReleaseDate?: boolean;
  showCharts?: boolean;
}
const { release: r, showReleaseDate = false, showCharts = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const cover = `${base}${r.artwork}`;
---
<a class="release-card" href={`${base}releases/${r.slug}/`}>
  {r.isCollab && <span class="badge">Collab</span>}
  {r.charts && r.charts.length > 0 && (
    <span class="badge" style="left:.6rem;right:auto;background:rgba(250,35,59,.85)">Charted</span>
  )}
  <img class="cover" src={cover} alt="" width="600" height="600" loading="lazy" decoding="async" />
  <div class="info">
    <span class="title">{r.title}</span>
    <span class="date">{showReleaseDate ? `${r.releaseDate} · ${r.typeLabel}` : r.typeLabel}</span>
    {showCharts && r.charts?.map((c) => (
      <span class="date" style="color:var(--accent);font-weight:600">{c}</span>
    ))}
  </div>
</a>
