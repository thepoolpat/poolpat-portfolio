---
import Base from "@/layouts/Base.astro";
import StatCard from "@/components/StatCard.astro";
import playsRaw from "@data/plays.json";
import historyRaw from "@data/history.csv?raw";

let playlistsData: any = { playlists: [] };
try {
  const mod = await import("@data/playlists.json");
  playlistsData = (mod as any).default ?? mod;
} catch (_) {}

const data = playsRaw as any;

const scTracks = data.soundcloud?.tracks || {};
const spTracks = data.spotify?.tracks || {};
const amTracks = data.apple_music?.tracks || {};

const scTotal = data.soundcloud?.total_plays_all_platforms || data.soundcloud?.total_plays || Object.values(scTracks).reduce((a: number, b: any) => a + (b || 0), 0);
const spTotal = data.spotify?.total_streams || Object.values(spTracks).reduce((a: number, b: any) => a + (b || 0), 0);
const amTotal = data.apple_music?.total_plays || Object.values(amTracks).reduce((a: number, b: any) => a + (b || 0), 0);
const grandTotal = data.soundcloud?.total_plays_all_platforms || (scTotal + spTotal + amTotal);

const scFollowers = data.soundcloud?.followers || 0;
const spMonthly = data.spotify?.monthly_listeners || 0;
const lastUpdated = data.last_updated ? new Date(data.last_updated).toLocaleDateString("en-IE", { day: "numeric", month: "short", year: "numeric" }) : "unknown";

function sortedTracks(tracks: Record<string, number>): [string, number][] {
  return Object.entries(tracks).filter(([, v]) => v != null).sort((a, b) => (b[1] || 0) - (a[1] || 0));
}

const scSorted = sortedTracks(scTracks);
const spSorted = sortedTracks(spTracks);
const amSorted = sortedTracks(amTracks);

const encodedHistory = encodeURIComponent(historyRaw);

const playlists: any[] = playlistsData.playlists || [];
const totalPlaylistReach = playlists.reduce((a: number, p: any) => a + (p.followers || 0), 0);
const playlistFetchedAt = playlistsData.fetched_at
  ? new Date(playlistsData.fetched_at).toLocaleDateString("en-IE", { day: "numeric", month: "short", year: "numeric" })
  : null;
---
<Base title="Poolpat &mdash; Play Stats" description="Live play count dashboard for Poolpat across SoundCloud, Spotify, and Apple Music." canonicalPath="/stats/">
  <h1>Play Stats</h1>
  <p class="muted">Updated daily &middot; Last: {lastUpdated}</p>

  <div class="stats-grid">
    <StatCard label="Total Plays" value={grandTotal} sub="All platforms" />
    <StatCard label="SoundCloud" value={scTotal} color="var(--accent-sc)" sub={`${scFollowers} followers`} />
    <StatCard label="Spotify" value={spTotal} color="var(--accent-sp)" sub={`${spMonthly} monthly listeners`} />
    <StatCard label="Apple Music" value={amTotal} color="var(--accent-am)" sub={`${data.apple_music?.total_shazams || 0} Shazams`} />
    {totalPlaylistReach > 0 && (
      <StatCard label="Playlist Reach" value={totalPlaylistReach} color="var(--accent-sp)" sub={`${playlists.length} playlists`} />
    )}
  </div>

  <section class="section">
    <h2>Play Count Trends</h2>
    <div class="chart-container">
      <canvas id="plays-chart" role="img" aria-label="Line chart showing play count trends over time for SoundCloud, Spotify, and Apple Music"></canvas>
      <div id="chart-data" data-history={encodedHistory} style="display:none"></div>
    </div>
  </section>

  <!-- Pinned + SRI-locked Chart.js (UMD, exposes window.Chart). Hash is for chart.js@4.5.0/dist/chart.umd.min.js -->
  <script
    src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.min.js"
    integrity="sha384-XcdcwHqIPULERb2yDEM4R0XaQKU3YnDsrTmjACBZyfdVVqjh6xQ4/DCMd7XLcA6Y"
    crossorigin="anonymous"
  ></script>
  <script type="module">
    (async () => {
      const dataEl = document.getElementById("chart-data");
      const canvas = document.getElementById("plays-chart");

      function parseCsv(raw) {
        const lines = raw.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
        if (lines.length < 2) return [];
        const headers = lines[0].split(",").map(h => h.trim());
        return lines.slice(1).map(line => {
          const values = line.split(",").map(v => v.trim());
          const row = {};
          headers.forEach((h, i) => { row[h] = values[i] !== undefined ? values[i] : ""; });
          return row;
        });
      }

      function toInt(v) {
        const n = parseInt(String(v || "").replace(/[^\d]/g, ""), 10);
        return isFinite(n) ? n : 0;
      }

      function clamp(arr) {
        let max = 0;
        return arr.map(v => { max = Math.max(max, v); return max; });
      }

      function nullifyZeros(arr) {
        // Log-scale rendering needs >0 values; let Chart.js skip the rest.
        return arr.map(v => v > 0 ? v : null);
      }

      const encoded = dataEl?.dataset?.history || "";
      const raw = decodeURIComponent(encoded);
      const rows = parseCsv(raw);

      if (!rows.length) {
        const p = document.createElement("p");
        p.className = "muted";
        p.textContent = "Trend data is not available yet.";
        canvas.replaceWith(p);
        return;
      }

      const labels = rows.map(r => {
        const d = new Date(r.timestamp);
        return isNaN(d) ? r.timestamp : d.toLocaleDateString("en-IE", { month: "short", day: "numeric", year: "numeric" });
      });

      const sc = nullifyZeros(clamp(rows.map(r => toInt(r.soundcloud_total_plays))));
      const sp = nullifyZeros(clamp(rows.map(r => toInt(r.spotify_total_streams || r.spotify_total_popularity))));
      const am = nullifyZeros(clamp(rows.map(r => toInt(r.apple_music_total_plays))));

      // Chart.js loaded via SRI-locked UMD <script> above; wait for the global.
      await new Promise((resolve) => {
        if (typeof window !== "undefined" && window.Chart) return resolve();
        const start = Date.now();
        const tick = setInterval(() => {
          if (typeof window !== "undefined" && window.Chart) {
            clearInterval(tick);
            resolve();
          } else if (Date.now() - start > 10000) {
            clearInterval(tick);
            resolve(); // bail; new Chart() below will throw a clear error
          }
        }, 30);
      });
      const Chart = window.Chart;
      // UMD bundle auto-registers all controllers/scales &mdash; no Chart.register() needed.

      new Chart(canvas, {
        type: "line",
        data: {
          labels,
          datasets: [
            {
              label: "SoundCloud",
              data: sc,
              borderColor: "#FF4000",
              backgroundColor: "rgba(255,64,0,0.15)",
              fill: true,
              tension: 0.4,
              borderWidth: 3,
              pointRadius: 0,
              pointHitRadius: 10,
              cubicInterpolationMode: "monotone",
              spanGaps: true
            },
            {
              label: "Spotify",
              data: sp,
              borderColor: "#1DB954",
              backgroundColor: "rgba(29,185,84,0.15)",
              fill: true,
              tension: 0.4,
              borderWidth: 3,
              pointRadius: 0,
              pointHitRadius: 10,
              cubicInterpolationMode: "monotone",
              spanGaps: true
            },
            {
              label: "Apple Music",
              data: am,
              borderColor: "#fa233b",
              backgroundColor: "rgba(250,35,59,0.15)",
              fill: true,
              tension: 0.4,
              borderWidth: 3,
              pointRadius: 0,
              pointHitRadius: 10,
              cubicInterpolationMode: "monotone",
              spanGaps: true
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: "top",
              labels: { color: "#f5f5f7", font: { size: 14, weight: "bold" }, padding: 20, boxWidth: 32, boxHeight: 14, generateLabels(chart) { return chart.data.datasets.map((ds, i) => ({ text: ds.label, fillStyle: "rgba(0,0,0,0)", strokeStyle: ds.borderColor, lineWidth: 3, hidden: !chart.isDatasetVisible(i), datasetIndex: i })); } }
            },
            title: {
              display: true,
              text: "Play Count History",
              color: "#f5f5f7",
              font: { size: 18, weight: "bold", family: "system-ui, -apple-system, sans-serif" },
              padding: { top: 10, bottom: 20 }
            },
            tooltip: {
              backgroundColor: "rgba(0,0,0,0.8)",
              titleColor: "#f5f5f7",
              bodyColor: "#f5f5f7",
              borderColor: "rgba(255,255,255,0.2)",
              borderWidth: 1,
              padding: 12,
              titleFont: { size: 14, weight: "bold" },
              bodyFont: { size: 13 }
            }
          },
          scales: {
            x: {
              ticks: { color: "#98989d", maxTicksLimit: 12, font: { size: 11 }, maxRotation: 0 },
              grid: { color: "rgba(240,240,245,0.08)" },
              title: { display: true, text: "Timeline", color: "#98989d", font: { size: 14, weight: "bold" } }
            },
            y: {
              type: "logarithmic",
              min: 1000,
              ticks: {
                color: "#98989d",
                // Only label decade values to declutter the log axis
                callback(value) {
                  const log = Math.log10(value);
                  if (Math.abs(log - Math.round(log)) > 1e-9) return null;
                  if (value < 1000) return Math.round(value).toLocaleString();
                  if (value < 1000000) return (value / 1000).toFixed(0) + "K";
                  return (value / 1000000).toFixed(1) + "M";
                }
              },
              grid: { color: "rgba(240,240,245,0.08)" },
              title: { display: true, text: "Cumulative Plays (log scale)", color: "#98989d", font: { size: 14, weight: "bold" } }
            }
          },
          elements: { line: { tension: 0.4, borderWidth: 3 }, point: { radius: 0, hitRadius: 10 } },
          animation: { duration: 1200, easing: "easeOutQuart" }
        }
      });
    })();
  </script>

  {playlists.length > 0 && (
    <section class="section">
      <h2>Playlist Placements &mdash; Spotify</h2>
      {playlistFetchedAt && <p class="muted" style="margin-bottom:1rem">Last checked: {playlistFetchedAt}</p>}
      <ul class="tracks">
        {playlists.slice(0, 20).map((p: any, i: number) => (
          <li class="track">
            <span class="track-num">{i + 1}</span>
            <a class="track-title" href={p.spotify_url} target="_blank" rel="noopener noreferrer" style="color:inherit;text-decoration:none">
              {p.name || p.playlist_id}
            </a>
            <span class="track-duration" style="color:var(--accent-sp)">
              {(p.followers || 0).toLocaleString("en-IE")} followers
            </span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="section">
    <h2>Top Tracks &mdash; SoundCloud</h2>
    <ul class="tracks">
      {scSorted.slice(0, 15).map(([title, plays], i) => (
        <li class="track">
          <span class="track-num">{i + 1}</span>
          <span class="track-title">{title}</span>
          <span class="track-duration" style={`color:var(--accent-sc)`}>{plays.toLocaleString("en-IE")}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <h2>Top Tracks &mdash; Spotify</h2>
    <ul class="tracks">
      {spSorted.slice(0, 15).map(([title, plays], i) => (
        <li class="track">
          <span class="track-num">{i + 1}</span>
          <span class="track-title">{title}</span>
          <span class="track-duration" style={`color:var(--accent-sp)`}>{plays.toLocaleString("en-IE")}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <h2>Top Tracks &mdash; Apple Music</h2>
    <ul class="tracks">
      {amSorted.slice(0, 15).map(([title, plays], i) => (
        <li class="track">
          <span class="track-num">{i + 1}</span>
          <span class="track-title">{title}</span>
          <span class="track-duration" style={`color:var(--accent-am)`}>{plays.toLocaleString("en-IE")}</span>
        </li>
      ))}
    </ul>
  </section>

  <nav class="nav-links" style="margin-top:2rem">
    <a class="nav-link" href={`${import.meta.env.BASE_URL}`}>&larr; Home</a>
    <a class="nav-link" href={`${import.meta.env.BASE_URL}discography/`}>Discography</a>
  </nav>
</Base>
