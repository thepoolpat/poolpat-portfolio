---
import Base from "@/layouts/Base.astro";
import StatCard from "@/components/StatCard.astro";
import playsRaw from "@data/plays.json";
import historyRaw from "@data/history.csv?raw";
import yearlyRaw from "@data/play_history_yearly.json";

let playlistsData: any = { playlists: [] };
try {
  const mod = await import("@data/playlists.json");
  playlistsData = (mod as any).default ?? mod;
} catch (_) {}

const data = playsRaw as any;

const scTracks = data.soundcloud?.tracks || {};
const spTracks = data.spotify?.tracks || {};
const amTracks = data.apple_music?.tracks || {};

const scTotal = data.soundcloud?.total_plays || Object.values(scTracks).reduce((a: number, b: any) => a + (b || 0), 0);
const spTotal = data.spotify?.total_streams || Object.values(spTracks).reduce((a: number, b: any) => a + (b || 0), 0);
const amTotal = data.apple_music?.total_plays || Object.values(amTracks).reduce((a: number, b: any) => a + (b || 0), 0);
// Grand total is ALWAYS the sum of the three displayed tiles, so the headline can
// never drift from its own breakdown. (A stale, manually-entered
// total_plays_all_platforms previously made the total disagree with the tiles.)
const grandTotal = scTotal + spTotal + amTotal;

const scFollowers = data.soundcloud?.followers || 0;
const spMonthly = data.spotify?.monthly_listeners || 0;
const lastUpdated = data.last_updated ? new Date(data.last_updated).toLocaleDateString("en-IE", { day: "numeric", month: "short", year: "numeric" }) : "unknown";

function sortedTracks(tracks: Record<string, number>): [string, number][] {
  return Object.entries(tracks).filter(([, v]) => v != null).sort((a, b) => (b[1] || 0) - (a[1] || 0));
}

const scSorted = sortedTracks(scTracks);
const spSorted = sortedTracks(spTracks);
const amSorted = sortedTracks(amTracks);

// ── Build-time chart series ───────────────────────────────────────────────
// Parse history.csv, aggregate to one row per UTC day, and project a monotonic
// cumulative series here at build time. The client receives only the final
// point arrays as compact JSON — no CSV parsing / decoding in the browser.
function parseCsvRows(raw: string): Record<string, string>[] {
  const lines = raw.split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
  if (lines.length < 2) return [];
  const headers = lines[0].split(",").map((h) => h.trim());
  return lines.slice(1).map((line) => {
    const values = line.split(",").map((v) => v.trim());
    const row: Record<string, string> = {};
    headers.forEach((h, i) => { row[h] = values[i] ?? ""; });
    return row;
  });
}
function toInt(v: string | undefined): number {
  const n = parseInt(String(v || "").replace(/[^\d]/g, ""), 10);
  return Number.isFinite(n) ? n : 0;
}
// Zeros are treated as MISSING DATA (null): nulls + spanGaps:true draw one
// smooth diagonal across the gap (e.g. AM stuck at 103 until the first AM4A
// capture in April 2026) instead of a flat plateau then a vertical jump.
// We intentionally do NOT force a monotonic (running-max) projection — a
// legitimate downward restatement (e.g. a SoundCloud purge of invalid plays)
// must show as a real decrease rather than being clamped up to the prior peak.
function projectSeries(arr: number[]): (number | null)[] {
  return arr.map((v) => (!v || v <= 0 ? null : v));
}

// ── Curated yearly spine (authoritative history) ──────────────────────────
// history.csv only carries trustworthy cross-platform totals from 2026-05-08
// on. Earlier 2026 rows undercount every platform: SoundCloud track discovery
// was still incomplete, and the Spotify / Apple Music figures were being
// backfilled, so they sit *below* the true year-end cumulative. For the run-up
// before that we use data/play_history_yearly.json — per-year plays read from
// the SoundCloud Insights "All Platforms" dashboard — as cumulative year-end
// points. (Each platform's annual values sum to its all-time total.)
const yearly = (yearlyRaw as any).annual_plays || {};
const nowMs = data.last_updated ? new Date(data.last_updated).getTime() : Date.now();
const nowYear = new Date(nowMs).getUTCFullYear();
function spinePoints(annual: Record<string, number> = {}): { x: number; y: number }[] {
  const years = Object.keys(annual).map(Number).filter((y) => Number.isFinite(y)).sort((a, b) => a - b);
  let cum = 0;
  const pts: { x: number; y: number }[] = [];
  for (const y of years) {
    cum += annual[String(y)] || 0;
    if (y < nowYear) pts.push({ x: Date.UTC(y, 6, 2), y: cum }); // plot the year's cumulative at the year's MIDPOINT, not Dec 31 — otherwise it lands on the Jan-of-next-year gridline and Spotify/Apple Music (first year 2023) look like they start in Jan 2024 instead of 2023
  }
  return pts;
}

// ── Live tail from history.csv: one row per UTC day (last reading wins), but
// only from the first all-platform-reliable capture onward. New weekly fetches
// land after this date, so the tail keeps extending itself automatically.
const FIRST_RELIABLE_TS = Date.UTC(2026, 4, 8); // 2026-05-08 — see note above
const dayMap = new Map<string, Record<string, string>>();
for (const r of parseCsvRows(historyRaw as string)) {
  const d = new Date(r.timestamp);
  if (isNaN(d.getTime()) || d.getTime() < FIRST_RELIABLE_TS) continue;
  dayMap.set(d.toISOString().slice(0, 10), r); // last reading of the day wins
}
const dayKeys = [...dayMap.keys()].sort();
const tailRows = dayKeys.map((k) => dayMap.get(k)!);
const tailXs = dayKeys.map((k) => new Date(k + "T00:00:00Z").getTime());

// ── Compose: yearly spine ++ live tail ++ current total (matches the tiles) ─
// projectSeries keeps the no-monotonic-forcing rule: a real restatement (e.g.
// the SoundCloud purge in the recent tail) still shows as a genuine dip.
function buildSeries(annualKey: string, csvCol: string, currentTotal: number): { x: number; y: number | null }[] {
  const pts = [
    ...spinePoints(yearly[annualKey]),
    ...tailXs.map((x, i) => ({ x, y: toInt(tailRows[i][csvCol]) })),
    { x: nowMs, y: currentTotal },
  ].sort((a, b) => a.x - b.x);
  const ys = projectSeries(pts.map((p) => p.y));
  return pts.map((p, i) => ({ x: p.x, y: ys[i] }));
}
const chartPoints = {
  sc: buildSeries("soundcloud", "soundcloud_total_plays", scTotal),
  sp: buildSeries("spotify", "spotify_total_streams", spTotal),
  am: buildSeries("apple_music", "apple_music_total_plays", amTotal),
};

const playlists: any[] = playlistsData.playlists || [];
const totalPlaylistReach = playlists.reduce((a: number, p: any) => a + (p.followers || 0), 0);
const playlistFetchedAt = playlistsData.fetched_at
  ? new Date(playlistsData.fetched_at).toLocaleDateString("en-IE", { day: "numeric", month: "short", year: "numeric" })
  : null;
---
<Base title="Poolpat &mdash; Play Stats" description="Live play count dashboard for Poolpat across SoundCloud, Spotify, and Apple Music." canonicalPath="/stats/">
  <h1>Play Stats</h1>
  <p class="muted">Updates every 24&ndash;48 hours from the SoundCloud Insights dashboard &middot; Last: {lastUpdated}</p>

  <div class="stats-grid">
    <StatCard label="Total Plays" value={grandTotal} sub="All platforms" />
    <StatCard label="SoundCloud" value={scTotal} color="var(--accent-sc)" sub={`${scFollowers} followers`} />
    <StatCard label="Spotify" value={spTotal} color="var(--accent-sp)" sub={`${spMonthly} monthly listeners`} />
    <StatCard label="Apple Music" value={amTotal} color="var(--accent-am)" sub={`${data.apple_music?.total_shazams || 0} Shazams`} />
    {totalPlaylistReach > 0 && (
      <StatCard label="Playlist Reach" value={totalPlaylistReach} color="var(--accent-sp)" sub={`${playlists.length} playlists`} />
    )}
  </div>

  <section class="section">
    <h2>Play Count Trends</h2>
    <div class="chart-container">
      <canvas id="plays-chart" role="img" aria-label="Line chart showing play count trends over time for SoundCloud, Spotify, and Apple Music"></canvas>
      <script id="chart-data" type="application/json" is:inline set:html={JSON.stringify(chartPoints)}></script>
    </div>
  </section>

  <!-- Chart.js is bundled & tree-shaken by Astro (ESM import below). No CDN, no SRI, no window global. -->
  <script>
    // @ts-nocheck — bundled client chart code (chart.js + raw DOM access). Kept
    // unchecked to match its prior inline status; it's plain runtime JS, not typed.
    import { Chart, LineController, LineElement, PointElement, LogarithmicScale, TimeScale, Legend, Title, Tooltip } from "chart.js";
    import "chartjs-adapter-date-fns";

    Chart.register(LineController, LineElement, PointElement, LogarithmicScale, TimeScale, Legend, Title, Tooltip);

    (async () => {
      // Series are computed at build time (see frontmatter) and shipped as
      // compact JSON — no client-side CSV parsing, aggregation, or decoding.
      const el = document.getElementById("chart-data");
      const canvas = document.getElementById("plays-chart");
      const { sc, sp, am } = JSON.parse(el?.textContent || '{"sc":[],"sp":[],"am":[]}');

      if (!sc.length && !sp.length && !am.length) {
        const p = document.createElement("p");
        p.className = "muted";
        p.textContent = "Trend data is not available yet.";
        canvas.replaceWith(p);
        return;
      }

      new Chart(canvas, {
        type: "line",
        data: {
          datasets: [
            {
              label: "SoundCloud",
              data: sc,
              borderColor: "#FF4000",
              backgroundColor: "#FF4000",
              fill: false,
              tension: 0,
              borderWidth: 2.5,
              pointRadius: 3,
              pointHoverRadius: 5,
              pointHitRadius: 10,
              spanGaps: true
            },
            {
              label: "Spotify",
              data: sp,
              borderColor: "#1DB954",
              backgroundColor: "#1DB954",
              fill: false,
              tension: 0,
              borderWidth: 2.5,
              pointRadius: 3,
              pointHoverRadius: 5,
              pointHitRadius: 10,
              spanGaps: true
            },
            {
              label: "Apple Music",
              data: am,
              borderColor: "#fa233b",
              backgroundColor: "#fa233b",
              fill: false,
              tension: 0,
              borderWidth: 2.5,
              pointRadius: 3,
              pointHoverRadius: 5,
              pointHitRadius: 10,
              spanGaps: true
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: "top",
              labels: {
                color: "#f5f5f7",
                font: { size: 14, weight: "bold" },
                padding: 20,
                boxWidth: 32,
                boxHeight: 14,
                generateLabels(chart) {
                  return chart.data.datasets.map((ds, i) => ({
                    text: ds.label,
                    fillStyle: ds.borderColor,
                    strokeStyle: ds.borderColor,
                    lineWidth: 0,
                    hidden: !chart.isDatasetVisible(i),
                    datasetIndex: i
                  }));
                }
              }
            },
            title: {
              display: true,
              text: "Play Count History",
              color: "#f5f5f7",
              font: { size: 18, weight: "bold", family: "system-ui, -apple-system, sans-serif" },
              padding: { top: 10, bottom: 20 }
            },
            tooltip: {
              backgroundColor: "rgba(0,0,0,0.8)",
              titleColor: "#f5f5f7",
              bodyColor: "#f5f5f7",
              borderColor: "rgba(255,255,255,0.2)",
              borderWidth: 1,
              padding: 12,
              titleFont: { size: 14, weight: "bold" },
              bodyFont: { size: 13 }
            }
          },
          scales: {
            x: {
              type: "time",
              time: {
                unit: "month",
                tooltipFormat: "d MMM yyyy",
                displayFormats: { day: "d MMM", month: "MMM yyyy", year: "yyyy" }
              },
              ticks: { color: "#98989d", maxTicksLimit: 12, font: { size: 11 }, maxRotation: 0, autoSkip: true },
              grid: { color: "rgba(240,240,245,0.08)" },
              title: { display: true, text: "Timeline", color: "#98989d", font: { size: 14, weight: "bold" } }
            },
            y: {
              type: "logarithmic",
              min: 10,
              ticks: {
                color: "#98989d",
                // Only label decade values to declutter the log axis
                callback(value) {
                  const log = Math.log10(value);
                  if (Math.abs(log - Math.round(log)) > 1e-9) return null;
                  if (value < 1000) return Math.round(value).toLocaleString();
                  if (value < 1000000) return (value / 1000).toFixed(0) + "K";
                  return (value / 1000000).toFixed(1) + "M";
                }
              },
              grid: { color: "rgba(240,240,245,0.08)" },
              title: { display: true, text: "Cumulative Plays (log scale)", color: "#98989d", font: { size: 14, weight: "bold" } }
            }
          },
          elements: { line: { tension: 0, borderWidth: 2.5 }, point: { radius: 3, hitRadius: 10 } },
          animation: { duration: 1200, easing: "easeOutQuart" }
        }
      });
    })();
  </script>

  {playlists.length > 0 && (
    <section class="section">
      <h2>Playlist Placements &mdash; Spotify</h2>
      {playlistFetchedAt && <p class="muted" style="margin-bottom:1rem">Last checked: {playlistFetchedAt}</p>}
      <ul class="tracks">
        {playlists.slice(0, 20).map((p: any, i: number) => (
          <li class="track">
            <span class="track-num">{i + 1}</span>
            <a class="track-title" href={p.spotify_url} target="_blank" rel="noopener noreferrer" style="color:inherit;text-decoration:none">
              {p.name || p.playlist_id}
            </a>
            <span class="track-duration" style="color:var(--accent-sp)">
              {(p.followers || 0).toLocaleString("en-IE")} followers
            </span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="section">
    <h2>Top Tracks &mdash; SoundCloud</h2>
    <ul class="tracks">
      {scSorted.slice(0, 15).map(([title, plays], i) => (
        <li class="track">
          <span class="track-num">{i + 1}</span>
          <span class="track-title">{title}</span>
          <span class="track-duration" style={`color:var(--accent-sc)`}>{plays.toLocaleString("en-IE")}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <h2>Top Tracks &mdash; Spotify</h2>
    <ul class="tracks">
      {spSorted.slice(0, 15).map(([title, plays], i) => (
        <li class="track">
          <span class="track-num">{i + 1}</span>
          <span class="track-title">{title}</span>
          <span class="track-duration" style={`color:var(--accent-sp)`}>{plays.toLocaleString("en-IE")}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <h2>Top Tracks &mdash; Apple Music</h2>
    <ul class="tracks">
      {amSorted.slice(0, 15).map(([title, plays], i) => (
        <li class="track">
          <span class="track-num">{i + 1}</span>
          <span class="track-title">{title}</span>
          <span class="track-duration" style={`color:var(--accent-am)`}>{plays.toLocaleString("en-IE")}</span>
        </li>
      ))}
    </ul>
  </section>

  <nav class="nav-links" style="margin-top:2rem">
    <a class="nav-link" href={`${import.meta.env.BASE_URL}`}>&larr; Home</a>
    <a class="nav-link" href={`${import.meta.env.BASE_URL}discography/`}>Discography</a>
  </nav>
</Base>
