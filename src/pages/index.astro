      <a class="social-icon" href="https://soundcloud.com/poolpat" target="_blank" rel="noopener noreferrer" aria-label="Poolpat on SoundCloud" title="SoundCloud" style="border-color:var(--accent-sc)">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M1.175 12.225c-.051 0-.094.046-.101.1l-.233 2.154.233 2.105c.007.058.05.098.101.098.05 0 .09-.04.099-.098l.255-2.105-.27-2.154c-.009-.06-.05-.1-.1-.1m-.899.828c-.06 0-.091.037-.104.094L0 14.479l.172 1.308c.013.06.045.094.104.094.057 0 .09-.038.104-.094l.194-1.308-.194-1.332c-.014-.057-.047-.094-.104-.094m1.8-1.148c-.065 0-.108.053-.114.108l-.22 2.466.22 2.375c.006.06.05.109.114.109.063 0 .108-.049.114-.109l.25-2.375-.25-2.466c-.006-.055-.051-.108-.114-.108m.899-.456c-.073 0-.12.06-.126.12l-.205 2.49.205 2.444c.006.066.053.12.126.12.071 0 .12-.054.126-.12l.232-2.444-.232-2.49c-.006-.06-.055-.12-.126-.12m.899-.342c-.083 0-.135.065-.139.132l-.194 2.508.194 2.472c.004.074.056.132.139.132.079 0 .135-.058.139-.132l.215-2.472-.215-2.508c-.004-.067-.06-.132-.139-.132m.9-.254c-.088 0-.147.074-.15.148l-.182 2.526.182 2.487c.003.074.062.148.15.148.088 0 .147-.074.15-.148l.208-2.487-.208-2.526c-.003-.074-.062-.148-.15-.148m.898-.19c-.098 0-.157.08-.16.159l-.17 2.544.17 2.504c.003.08.062.159.16.159.096 0 .157-.08.16-.159l.194-2.504-.194-2.544c-.003-.08-.064-.159-.16-.159m.9-.126c-.1 0-.167.089-.17.17l-.158 2.562.158 2.514c.003.088.07.17.17.17.1 0 .167-.082.17-.17l.18-2.514-.18-2.562c-.003-.081-.07-.17-.17-.17m.899-.063c-.108 0-.177.094-.18.181l-.146 2.58.146 2.525c.003.09.072.18.18.18.107 0 .177-.09.18-.18l.166-2.525-.166-2.58c-.003-.087-.073-.181-.18-.181m2.699-1.17c-.12 0-.193.105-.197.199l-.122 3.763.122 2.536c.004.098.077.199.197.199.118 0 .193-.101.197-.199l.139-2.536-.139-3.763c-.004-.094-.079-.199-.197-.199m-.899.438c-.116 0-.189.1-.193.193l-.134 3.325.134 2.536c.004.094.077.193.193.193.114 0 .189-.099.193-.193l.152-2.536-.152-3.325c-.004-.093-.079-.193-.193-.193m1.8-1.1c-.128 0-.203.11-.207.211l-.11 4.413.11 2.528c.004.105.079.211.207.211.125 0 .203-.106.207-.211l.126-2.528-.126-4.413c-.004-.101-.082-.211-.207-.211m.9-.388c-.135 0-.214.119-.217.222l-.098 4.801.098 2.52c.003.108.082.222.217.222.133 0 .214-.114.2