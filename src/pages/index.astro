      </a>
      <a class="social-icon" href="https://open.spotify.com/artist/4rr3o9anpUXitNXo0W4uX7" target="_blank" rel="noopener noreferrer" aria-label="Poolpat on Spotify" title="Spotify" style="border-color:var(--accent-sp)">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
      </a>
      <a class="social-catchall" href="https://ffm.bio/poolpat" target="_blank" rel="noopener noreferrer" aria-label="All Poolpat links on FFM">Stream &amp; Connect</a>
    </nav>
  </header>

  <!-- Hero Carousel -->
  <section class="hero" role="region" aria-roledescription="carousel" aria-label="Featured releases">
    <div class="hero-stage" id="hero-stage">
      {releases.map((r, i) => (
        <div class={`hero-slide${i === 0 ? " active" : ""}`} data-idx={i}>
          <div class="artwork">
            <img src={art(r)} alt={`${r.title} cover artwork`} loading={i === 0 ? "eager" : "lazy"} decoding="async" />
          </div>
          <h1>{r.title}</h1>
          <p class="tagline">{r.tagline}</p>
          <div class="meta">
            <span class="badge-type">{r.typeLabel}</span>
            {r.meta?.map((m) => <span>{m}</span>)}
            {r.charts?.map((c) => <ChartBadge position={c} />)}
          </div>
          <ListenButton
            storefront={r.storefront}
            type={r.type as "album"}
            slug={r.slug}
            id={r.id}
            campaign={`web-portfolio-${r.slug}-hero`}
          />
        </div>
      ))}
    </div>
    <div class="hero-controls">
      <button class="nav-btn" id="prev-btn" aria-label="Previous release">&lsaquo;</button>
      <div class="hero-dots" id="hero-dots">
        {releases.map((r, i) => (
          <button class={`dot${i === 0 ? " active" : ""}`} data-idx={i} aria-label={`Show ${r.title}`} title={r.title}></button>
        ))}
      </div>
      <button class="nav-btn" id="next-btn" aria-label="Next release">&rsaquo;</button>
    </div>
    <div class="rotation-status" id="rotation-status" aria-live="polite">Auto-rotating</div>
  </section>

  <!-- Quick Stats -->
  <section class="section">
    <h2>Live Stats</h2>
    <div class="stats-grid">
      <StatCard label="Total Plays" value={grandTotal} sub="All platforms" />
      <StatCard label="SoundCloud" value={scTotal} color="var(--accent-sc)" />
      <StatCard label="Spotify" value={spTotal} color="var(--accent-sp)" />
      <StatCard label="Apple Music" value={amTotal} color="var(--accent-am)" />
    </div>
    <p class="muted" style="text-align:center;margin-top:.5rem">
      <a href={`${import.meta.env.BASE_URL}stats/`}>Full stats dashboard &rarr;</a>
    </p>
  </section>

  <!-- Discography Preview -->
  <section class="section">
    <h2>Discography</h2>
    <div class="releases">
      {releases.slice(0, 4).map((r) => (
        <a class="release-card" href={`${import.meta.env.BASE_URL}releases/${r.slug}/`}>
          {r.isCollab && <span class="badge">Collab</span>}
          {r.charts?.length && <span class="badge" style="left:.6rem;right:auto;background:rgba(250,35,59,.85)">Charted</span>}
          <div class="cover" style={`background-image:url('${art(r)}')`}></div>
          <div class="info">
            <span class="title">{r.title}</span>
            <span class="date">{r.typeLabel}</span>
          </div>
        </a>
      ))}
    </div>
    <p class="muted" style="text-align:center;margin-top:.5rem">
      <a href={`${import.meta.env.BASE_URL}discography/`}>View full discography &rarr;</a>
    </p>
  </section>

  <!-- Listen Links -->
  <section class="section">
    <h2>Listen</h2>
    <nav class="nav-links" style="justify-content:center">
      <a class="nav-link" href="https://music.apple.com/ie/artist/poolpat/1716939831?at=1000l3chz&app=music&ct=web-portfolio-listen-am" target="_blank" rel="noopener noreferrer" style="border-color:var(--accent-am)">Apple Music</a>
      <a class="nav-link" href="https://open.spotify.com/artist/4rr3o9anpUXitNXo0W4uX7" target="_blank" rel="noopener noreferrer" style="border-color:var(--accent-sp)">Spotify</a>
      <a class="nav-link" href="https://soundcloud.com/poolpat" target="_blank" rel="noopener noreferrer" style="border-color:var(--accent-sc)">SoundCloud</a>
      <a class="nav-link" href="https://ffm.bio/poolpat" target="_blank" rel="noopener noreferrer">Stream &amp; Connect</a>
    </nav>
  </section>

  <!-- Navigation -->
  <nav class="nav-links" aria-label="Site navigation">
    <a class="nav-link" href={`${import.meta.env.BASE_URL}stats/`}>Play Stats</a>
    <a class="nav-link" href={`${import.meta.env.BASE_URL}discography/`}>Full Discography</a>
    <a class="nav-link" href="https://ffm.bio/poolpat" target="_blank" rel="noopener noreferrer">Stream &amp; Connect</a>
  </nav>

  <!-- Carousel Script -->
  <script>
    const slides = document.querySelectorAll<HTMLElement>(".hero-slide");
    const dots = document.querySelectorAll<HTMLElement>(".dot");
    const status = document.getElementById("rotation-status")!;
    const ROTATE_MS = 8000;
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let paused = false;

    function showSlide(i: number) {
      current = (i + slides.length) % slides.length;
      slides.forEach((s, idx) => s.classList.toggle("active", idx === current));
      dots.forEach((d, idx) => {
        d.classList.toggle("active", idx === current);
        d.setAttribute("aria-current", idx === current ? "true" : "false");
      });
      const title = slides[current].querySelector("h1")?.textContent ?? "";
      status.textContent = paused
        ? `Paused on ${title}`
        : `Auto-rotating \u00b7 ${current + 1} of ${slides.length}`;
    }

    function next() { showSlide(current + 1); }
    function prev() { showSlide(current - 1); }
    function restartTimer() {
      if (timer) clearInterval(timer);
      if (!paused) timer = setInterval(next, ROTATE_MS);
    }

    document.getElementById("next-btn")!.addEventListener("click", () => { next(); restartTimer(); });
    document.getElementById("prev-btn")!.addEventListener("click", () => { prev(); restartTimer(); });
    dots.forEach(d => d.addEventListener("click", (e) => {
      showSlide(parseInt((e.currentTarget as HTMLElement).dataset.idx!, 10));
      restartTimer();
    }));

    const hero = document.querySelector(".hero")!;
    hero.addEventListener("mouseenter", () => { paused = true; showSlide(current); restartTimer(); });
    hero.addEventListener("mouseleave", () => { paused = false; showSlide(current); restartTimer(); });

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      paused = true;
      showSlide(0);
    } else {
      restartTimer();
    }
  </script>
</Base>
