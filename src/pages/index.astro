---
import Base from "@/layouts/Base.astro";
import ListenButton from "@/components/ListenButton.astro";
import ChartBadge from "@/components/ChartBadge.astro";
import StatCard from "@/components/StatCard.astro";
import releases from "@/data/releases.json";
import playsRaw from "@data/plays.json";

const data = playsRaw as any;
const base = import.meta.env.BASE_URL;
const art = (r: any) => `${base}${r.artwork}`;
const scTotal = data.soundcloud?.total_plays_all_platforms || data.soundcloud?.total_plays || 0;
const spTotal = data.spotify?.total_streams || 0;
const amTotal = data.apple_music?.total_plays || 0;
const grandTotal = scTotal + spTotal + amTotal;
---
<Base title="Poolpat — Cork Hip-Hop" description="Poolpat — Cork hip-hop artist. Live play stats, full discography, and liner notes across SoundCloud, Spotify, and Apple Music.">

  <!-- Artist Header -->
  <header class="artist-header">
    <a class="artist-name" href="https://music.apple.com/ie/artist/poolpat/1716939831?at=1000l3chz&app=music&ct=web-portfolio-nameplate" target="_blank" rel="noopener noreferrer" aria-label="Poolpat artist page on Apple Music">Poolpat</a>
    <div class="artist-follow">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M23.994 6.124a3.005 3.005 0 0 0-2.118-2.118C19.948 3.5 12 3.5 12 3.5s-7.948 0-9.876.506A3.005 3.005 0 0 0 .006 6.124C-.5 8.052-.5 12-.5 12s0 3.948.506 5.876a3.005 3.005 0 0 0 2.118 2.118C4.052 20.5 12 20.5 12 20.5s7.948 0 9.876-.506a3.005 3.005 0 0 0 2.118-2.118C24.5 15.948 24.5 12 24.5 12s0-3.948-.506-5.876z"/><path d="M9.545 15.568V8.432L15.818 12z" fill="var(--bg)"/></svg>
      Follow on Apple Music
