---
import Base from "@/layouts/Base.astro";
import ListenButton from "@/components/ListenButton.astro";
import ReleaseMeta from "@/components/ReleaseMeta.astro";
import { getCollection } from "astro:content";
import { hashCampaign } from "@affiliate";

export async function getStaticPaths() {
  const releases = await getCollection("releases");
  return releases.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { release: entry.data },
  }));
}

const { release } = Astro.props;
const r = release;
const base = import.meta.env.BASE_URL;
const site = import.meta.env.SITE ?? "https://thepoolpat.github.io";
const artUrl = `${base}${r.artwork}`;
// Page renders WebP; social cards (og:image/twitter:image) use a JPEG sibling —
// some link scrapers still don't reliably support WebP. See public/artwork/*.jpg.
const ogImageUrl = artUrl.replace(/\.webp$/, ".jpg");
const safeCredits = r.credits?.replace(/<(?!\/?(?:strong|em|br)\b)[^>]*>/gi, "") ?? "";

function toIsoDuration(d?: string): string | undefined {
  if (!d) return undefined;
  const parts = d.split(":").map((n) => parseInt(n, 10));
  if (parts.some(Number.isNaN)) return undefined;
  let h = 0, m = 0, s = 0;
  if (parts.length === 3) [h, m, s] = parts;
  else if (parts.length === 2) [m, s] = parts;
  else return undefined;
  return `PT${h ? `${h}H` : ""}${m}M${s}S`;
}

const albumJsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicAlbum",
  name: r.title,
  byArtist: { "@id": `${site}${base}#artist` },
  url: `${site}${base}releases/${r.slug}/`,
  image: `${site}${artUrl}`,
  ...(r.releaseDate ? { datePublished: r.releaseDate } : {}),
  numTracks: r.tracks?.length,
  track: r.tracks?.map((t, i) => ({
    "@type": "MusicRecording",
    position: i + 1,
    name: t.title,
    ...(toIsoDuration(t.duration) ? { duration: toIsoDuration(t.duration) } : {}),
  })),
};
---
<Base
  title={`${r.title} — Poolpat`}
  description={r.tagline}
  ogImage={ogImageUrl}
  ogType="music.album"
  canonicalPath={`/releases/${r.slug}/`}
  structuredData={albumJsonLd}
>
  <a href={`${base}discography/`} class="muted" style="font-size:.9rem">&larr; All releases</a>

  <div class="artwork">
    <img src={artUrl} alt={`${r.title} cover artwork`} width="1200" height="1200" loading="eager" decoding="async" />
  </div>

  <h1>{r.title}</h1>
  <p class="tagline">{r.tagline}</p>

  <ReleaseMeta release={r} />

  {r.sections?.map((s) => (
    <section class="section" id={s.id}>
      <h2>{s.title}</h2>
      <p>{s.body}</p>
    </section>
  ))}

  <section class="section">
    <h2>Tracks</h2>
    <ul class="tracks">
      {r.tracks.map((t, i) => (
        <li class="track">
          <span class="track-num">{i + 1}</span>
          <span class="track-title">{t.title}</span>
          <span class="track-duration">{t.duration}</span>
          <ListenButton
            small
            storefront={r.storefront}
            type="song"
            slug={t.slug}
            id={t.id}
            campaign={hashCampaign(`web-portfolio-${r.slug}-t${i + 1}`)}
          />
        </li>
      ))}
    </ul>
  </section>

  {r.credits && (
    <section class="section">
      <h2>Credits</h2>
      <p set:html={safeCredits} />
    </section>
  )}

  <section class="section" style="text-align:center">
    <ListenButton
      storefront={r.storefront}
      type={r.type as "album"}
      slug={r.slug}
      id={r.id}
      campaign={hashCampaign(`web-portfolio-${r.slug}-cta`)}
    >
      Listen to the Full Album on Apple Music
    </ListenButton>
  </section>
</Base>
