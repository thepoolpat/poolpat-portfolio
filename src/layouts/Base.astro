---
import "@/styles/global.css";
import SEOHead from "@/components/SEOHead.astro";
import { link, hashCampaign } from "@affiliate";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "music.album" | "music.song";
  canonicalPath?: string;
  structuredData?: object;
}
const {
  title,
  description = "Poolpat — Cork trip-hop artist. Live play stats, discography, and liner notes across SoundCloud, Spotify, and Apple Music.",
  ogImage = `${import.meta.env.BASE_URL}artwork/artist-banner.png`,
  ogType = "website",
  canonicalPath,
  structuredData,
} = Astro.props;

const siteUrl = import.meta.env.SITE ?? "https://thepoolpat.github.io";
const canonical = `${siteUrl}${import.meta.env.BASE_URL}${(canonicalPath ?? "").replace(/^\//, "")}`;
const developerToken = import.meta.env.MUSICKIT_DEVELOPER_TOKEN ?? "";

const footerAmHref = link({
  storefront: "ie",
  type: "artist",
  slug: "poolpat",
  id: "1716939831",
  campaign: hashCampaign("web-portfolio-footer-artist"),
});
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0b0b0c" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://js-cdn.music.apple.com; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; frame-src https://open.spotify.com https://w.soundcloud.com https://embed.music.apple.com; connect-src 'self'" />
  <SEOHead
    title={title}
    description={description}
    ogImage={ogImage}
    ogType={ogType}
    canonicalUrl={canonical}
    structuredData={structuredData}
  />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  {developerToken && (
    <script
      src="https://js-cdn.music.apple.com/musickit/v3/musickit.js"
      integrity="sha384-P9rZEwFDysMpb6eyJui9TfC88AoAPDelBRR7EdZEmimWpQ3Auy8uhmqcTUeeXrJR"
      crossorigin="anonymous"
      data-web-components
      async
    ></script>
  )}
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <main id="main-content">
    <slot />
    <footer>
      &copy; Poolpat &middot; Cork, Ireland &middot;
      <a href={footerAmHref} target="_blank" rel="noopener">Apple Music</a> &middot;
      <a href="https://soundcloud.com/poolpat" target="_blank" rel="noopener">SoundCloud</a> &middot;
      <a href="https://open.spotify.com/artist/4rr3o9anpUXitNXo0W4uX7" target="_blank" rel="noopener">Spotify</a>
    </footer>
  </main>
</body>
</html>
